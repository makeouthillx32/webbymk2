{
  "compilerOptions": {
    "lib": ["dom", "dom.iterable", "esnext"],
    // baseUrl is tui/ — all paths below are relative to here
    "baseUrl": ".",
    "paths": {
      // Core app utilities, types, and lib functions (non-React-19 code)
      // baseUrl is src/tui/ — one level up lands in src/, which is @/*
      "@/*": ["../*"],
      // Pin ink to tui/node_modules (React 18 build) — not the root React 19 copy
      "ink": ["./node_modules/ink/build/index.js"],
      "ink/*": ["./node_modules/ink/build/*"]
    },
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "node",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "target": "ES2017"
  },
  // Include all .ts/.tsx in src/ink/ and imported src/config/ files.
  // "../config/**" is relative to this tsconfig (src/ink/) → resolves to src/config/
  // Without it, Bun's --watch reports "not in project directory" for config imports.
  "include": ["**/*.ts", "**/*.tsx", "../config/**/*.ts"],
  "exclude": ["node_modules"]
}
