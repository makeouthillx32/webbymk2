# External URL for GoTrue + Studio
API_EXTERNAL_URL=https://unenter.live

# ─── App ──────────────────────────────────────────────────────
APP_PORT=3000
SITE_URL=https://unenter.live
ADDITIONAL_REDIRECT_URLS=http://localhost:3000

# ─── Kong ports (offset from Mission Control) ─────────────────
